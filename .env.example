SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql://ishemalink:password@localhost:5432/ishemalink_db
DB_NAME=ishemalink_db
DB_USER=ishemalink
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# Security
ALLOWED_HOSTS=localhost,127.0.0.1
SECURE_SSL_REDIRECT=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Field-Level Encryption (Fernet Key)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-encryption-key-here-generate-once

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# SMS Gateway (for OTP)
SMS_GATEWAY_URL=mock://localhost
SMS_GATEWAY_API_KEY=your-sms-gateway-api-key
