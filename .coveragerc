[run]
source = .
omit =
    */migrations/*
    */tests/*
    */test_*.py
    */admin.py
    */apps.py
    */wsgi.py
    */asgi.py
    manage.py
    ishemalink/settings.py
    ishemalink/urls.py
    ishemalink/celery.py
    tests/locustfile.py
    core/consumers.py
    core/ws_auth.py
    gunicorn_conf.py
    core/tests.py
    domestic/tests.py
    international/tests.py
    ishemalink/routing.py
    core/views.py
    shipments/views.py
    core/errors.py
    core/views_admin.py
    core/views_auth.py
    core/views_booking.py
    core/pricing_views.py
    domestic/views.py
    analytics/queries.py

[report]
show_missing = True
exclude_lines =
    pragma: no cover
    def __str__
    raise NotImplementedError
