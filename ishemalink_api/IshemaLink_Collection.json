{
  "info": {
    "name": "IshemaLink API Collection",
    "description": "Complete API collection for IshemaLink logistics platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
